# COGNITUM Environment Configuration

# Application Settings
TIMEZONE=America/Sao_Paulo

# Gemini SDK Configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Centralized model to standardize on across the entire repo
GEMINI_MODEL=gemini-2.5-flash

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Kimi Proxy (optional local AI provider)
KIMI_PROXY_URL=http://localhost:3000

# Base Directories (defaults to repository root subfolders if left blank)
# COGNITUM_BASE_DIR=/home/engthi/Projetos/COGNITUM
# DATABASE_PATH=/home/engthi/Projetos/COGNITUM/data/cognitum.db
# VAULT_DIR=/home/engthi/Projetos/COGNITUM/vault
# MEMORY_DIR=/home/engthi/Projetos/COGNITUM/memory
# PROFILES_DIR=/home/engthi/Projetos/COGNITUM/profiles
# POLICIES_DIR=/home/engthi/Projetos/COGNITUM/policies

# Global HTTP Timeout
HTTP_TIMEOUT=30.0

# MCP Servers (JSON array de {id, command})
# MCP_SERVERS_JSON=[{"id":"filesystem","command":"npx -y @modelcontextprotocol/server-filesystem /opt/automation"},{"id":"github","command":"npx -y @modelcontextprotocol/server-github"}]

# Composio
COMPOSIO_API_KEY=

# HackClub AI (OpenRouter-compatible)
OPENROUTER_API_KEY=
